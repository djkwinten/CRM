# ── Brevo Transactional Email Config ──
#
# Cloudflare Workers ondersteunen geen klassieke SMTP sockets.
# Deze app verstuurt e-mail via de Brevo HTTP API.
# Maak een API key aan in Brevo:
#   Brevo → SMTP & API → API Keys → Generate new API key
#
# Gebruik BREVO_API_KEY bij voorkeur. SMTP_PASS blijft ondersteund als oude naam.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=jouw-afzender@domein.be
SMTP_FROM=jouw-afzender@domein.be
BREVO_API_KEY=xkeysib-...
# SMTP_PASS=xkeysib-...

# De publieke URL van de app (voor links in e-mails)
APP_URL=http://localhost:5173
