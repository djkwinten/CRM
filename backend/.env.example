# ── SMTP Configuratie voor automatische herinneringen ──
#
# Gebruik Gmail met een App Password:
#   1. Ga naar https://myaccount.google.com/apppasswords
#   2. Maak een App Password aan voor "Mail"
#   3. Vul hieronder in

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=jouw.email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# De publieke URL van de app (voor links in e-mails)
APP_URL=http://localhost:5173
